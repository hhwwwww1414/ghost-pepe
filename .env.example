# ============================================================================
# Ghost Pepe VPN — environment template
# Copy to .env.local (local dev) or .env.production (servers) and fill in.
# NEVER commit the filled file. See infra/secrets/secrets.local.example.md.
# ============================================================================

# ---------- App ----------
APP_NAME="Ghost Pepe VPN"
NODE_ENV=development
LOG_LEVEL=info

# Public base URLs (used to build links shown to users)
PUBLIC_BASE_URL=http://localhost:8082
API_BASE_URL=http://localhost:8080
ADMIN_BASE_URL=http://localhost:8083

# ---------- Domains (production) ----------
ROOT_DOMAIN=example.com
API_DOMAIN=api.example.com
ADMIN_DOMAIN=admin.example.com
SUB_DOMAIN=sub.example.com
FI_VLESS_DOMAIN=fi-vless.example.com
FI_HYSTERIA_DOMAIN=fi-hy.example.com
DE_VLESS_DOMAIN=de-vless.example.com
DE_HYSTERIA_DOMAIN=de-hy.example.com
WL_VLESS_DOMAIN=wl-vless.example.com
WL_HYSTERIA_DOMAIN=wl-hy.example.com

# ---------- Ports (local services) ----------
API_PORT=8080
HYSTERIA_AUTH_PORT=18081
SUB_PORT=8082
ADMIN_PORT=8083
BOT_INTERNAL_PORT=8084

# ---------- Database ----------
POSTGRES_USER=ghostpepe
POSTGRES_PASSWORD=ghostpepe_dev_password
POSTGRES_DB=ghostpepe
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ghostpepe:ghostpepe_dev_password@localhost:5432/ghostpepe?schema=public

# ---------- Redis ----------
REDIS_PASSWORD=ghostpepe_redis_dev
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:ghostpepe_redis_dev@localhost:6379

# ---------- Telegram bot ----------
TELEGRAM_BOT_TOKEN=000000:CHANGE_ME
TELEGRAM_BOT_USERNAME=ghostpepebot
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_webhook_secret
TELEGRAM_ADMIN_IDS=
# Run bot via long-polling locally; set a URL to use webhook mode.
TELEGRAM_WEBHOOK_URL=
BOT_MODE=polling

# ---------- Telegram Stars ----------
# For Stars the provider_token MUST be an empty string. Keep var explicit/testable.
STARS_PROVIDER_TOKEN=
STARS_CURRENCY=XTR

# ---------- Auth / internal tokens ----------
ADMIN_JWT_SECRET=CHANGE_ME_admin_jwt_secret_min_32_chars
INTERNAL_API_TOKEN=CHANGE_ME_internal_api_token
NODE_AGENT_TOKEN=CHANGE_ME_node_agent_token
SUBSCRIPTION_TOKEN_SECRET=CHANGE_ME_subscription_token_secret
# Master key used to encrypt VLESS/Hysteria credential material at rest (32 bytes hex/base64).
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_byte_key_base64_or_hex
# HMAC secret used to derive token/fingerprint hashes stored in DB.
TOKEN_HASH_SECRET=CHANGE_ME_token_hash_secret

# Default admin bootstrap (created by db:seed if not present)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=changeme-admin

# ---------- Happ ----------
HAPP_PROVIDER_ID=
HAPP_SUBSCRIPTION_NAME="Ghost Pepe"
HAPP_SUPPORT_URL=https://t.me/ghostpepe_support
HAPP_PROFILE_UPDATE_INTERVAL=6

# ---------- Xray Reality (per node) ----------
FI_REALITY_PRIVATE_KEY=
FI_REALITY_PUBLIC_KEY=
FI_REALITY_SHORT_ID=
FI_REALITY_SERVER_NAME=www.microsoft.com
DE_REALITY_PRIVATE_KEY=
DE_REALITY_PUBLIC_KEY=
DE_REALITY_SHORT_ID=
DE_REALITY_SERVER_NAME=www.microsoft.com
YC_REALITY_PRIVATE_KEY=
YC_REALITY_PUBLIC_KEY=
YC_REALITY_SHORT_ID=
YC_REALITY_SERVER_NAME=www.microsoft.com

# ---------- Hysteria (per node) ----------
FI_HYSTERIA_TRAFFIC_API_SECRET=
DE_HYSTERIA_TRAFFIC_API_SECRET=
YC_HYSTERIA_TRAFFIC_API_SECRET=
FI_HYSTERIA_OBFS_PASSWORD=
DE_HYSTERIA_OBFS_PASSWORD=
YC_HYSTERIA_OBFS_PASSWORD=

# ---------- Node-agent (runs on each server) ----------
NODE_CODE=fi-control-01
CONTROL_PLANE_URL=http://localhost:8080
XRAY_API_ADDR=127.0.0.1:10085
HYSTERIA_STATS_ADDR=127.0.0.1:9999
STATS_POLL_INTERVAL_SEC=30
HEARTBEAT_INTERVAL_SEC=30

# ---------- Port mode ----------
# A = HAProxy SNI router on TCP 443 (production). B = simple fallback (VLESS on 8443).
PORT_MODE=A
