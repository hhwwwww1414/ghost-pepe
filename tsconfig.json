{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "types": ["node"],
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@ghostpepe/shared": ["packages/shared/src/index.ts"],
      "@ghostpepe/config": ["packages/config/src/index.ts"],
      "@ghostpepe/db": ["packages/db/src/index.ts"],
      "@ghostpepe/vpn-config": ["packages/vpn-config/src/index.ts"],
      "@ghostpepe/routing-rules": ["packages/routing-rules/src/index.ts"],
      "@ghostpepe/billing": ["packages/billing/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/test/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist/**", "**/node_modules/**"]
}
