# Admin web (Vite build served by Caddy/static). Dev uses the node image instead.
FROM node:22-slim AS build
WORKDIR /app
COPY apps/admin-web/package.json apps/admin-web/
RUN cd apps/admin-web && npm install --no-audit --no-fund
COPY apps/admin-web apps/admin-web
ARG VITE_API_BASE_URL=https://api.example.com
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN cd apps/admin-web && npm run build

FROM caddy:2-alpine
COPY --from=build /app/apps/admin-web/dist /usr/share/caddy
