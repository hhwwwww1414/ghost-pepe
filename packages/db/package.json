{
  "name": "@ghostpepe/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy || prisma db push --accept-data-loss",
    "push": "prisma db push --accept-data-loss",
    "migrate:dev": "prisma migrate dev",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@ghostpepe/config": "*",
    "@ghostpepe/shared": "*",
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsx": "^4.19.2"
  }
}
